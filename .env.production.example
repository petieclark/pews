# Pews Production Environment Configuration
# Copy this file to .env.production and fill in your values
# DO NOT commit .env.production to version control

# ============================================
# Domain Configuration
# ============================================
# Primary domain for the application
DOMAIN=demo.pews.app

# Full URL including protocol (used by backend for CORS and frontend for API calls)
FRONTEND_URL=https://demo.pews.app

# ============================================
# Database Configuration
# ============================================
# PostgreSQL database name
POSTGRES_DB=pews

# PostgreSQL username
POSTGRES_USER=pews

# PostgreSQL password (also stored in secrets/db_password.txt for Docker secrets)
# This is used for initial setup; the container reads from /run/secrets/db_password
DB_PASSWORD=change-this-strong-password-min-32-chars

# ============================================
# Security Secrets
# ============================================
# JWT signing secret - MUST be strong and random (min 64 chars recommended)
# Also store in secrets/jwt_secret.txt
# Generate with: openssl rand -hex 64
JWT_SECRET=change-this-jwt-secret-min-64-chars-use-openssl-rand

# ============================================
# Stripe Payment Configuration
# ============================================
# Stripe secret API key (sk_live_xxx for production, sk_test_xxx for testing)
# Also store in secrets/stripe_secret_key.txt
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe webhook signing secret (whsec_xxx)
# Get this from Stripe Dashboard -> Developers -> Webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Price ID for subscription (price_xxx)
# Get this from Stripe Dashboard -> Products -> Your Product -> Pricing
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx

# ============================================
# Application Configuration
# ============================================
# Backend server port (internal to container)
PORT=8080

# Frontend server port (internal to container)
FRONTEND_PORT=3000

# ============================================
# Docker Compose Settings
# ============================================
# Compose project name (defaults to directory name if not set)
COMPOSE_PROJECT_NAME=pews

# ============================================
# Resource Limits (Optional Overrides)
# ============================================
# Uncomment and adjust if you need different limits than docker-compose.prod.yml defaults
# POSTGRES_MEMORY_LIMIT=512M
# BACKEND_MEMORY_LIMIT=1G
# FRONTEND_MEMORY_LIMIT=512M
# POSTGRES_CPU_LIMIT=1.0
# BACKEND_CPU_LIMIT=2.0
# FRONTEND_CPU_LIMIT=1.0

# ============================================
# Backup Configuration
# ============================================
# Number of daily backups to retain (used by scripts/backup.sh)
BACKUP_RETENTION_DAYS=7

# Backup directory (absolute path or relative to project root)
BACKUP_DIR=./backups

# ============================================
# Deployment Configuration
# ============================================
# SSH target for remote deployment (user@host)
DEPLOY_TARGET=CTMProd@ctmprod

# Remote directory where the application is deployed
DEPLOY_PATH=/home/CTMProd/pews-demo

# Docker image registry (leave empty for local-only or set to your registry)
# Example: registry.example.com/pews
DOCKER_REGISTRY=

# ============================================
# Monitoring & Logging
# ============================================
# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable structured JSON logging (true/false)
LOG_JSON=true

# ============================================
# SendGrid Email Configuration
# ============================================
# SendGrid API key for email delivery
SENDGRID_API_KEY=SG.your_production_sendgrid_api_key_here

# Default from email address (must be verified domain in SendGrid)
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Default from name displayed to recipients
SENDGRID_FROM_NAME=Pews Church Management

# ============================================
# Twilio SMS Configuration
# ============================================
# Twilio Account SID (found in Twilio Console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Auth Token (found in Twilio Console)
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Verified phone number to send from (must be verified in Twilio)
TWILIO_FROM_NUMBER=+15551234567

# ============================================
# Development Mode
# ============================================
# Set to "true" to prevent actual sends during local dev (logs only)
DEV_MODE=false
